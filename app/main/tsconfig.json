{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "module": "esnext",
    "target": "ESNext",
    "sourceMap": false,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "types": ["node", "electron"],
    "paths": {
      "@app/*": ["../*"]
    }
  },
  "include": ["src/**/*.ts", "../../types/**/*.d.ts"],
}

